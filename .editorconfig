# https://editorconfig.org
# Cross-editor formatting baseline. Rust source obeys rustfmt.toml at
# build/CI time; this file just keeps lightweight files (md/yml/json/sh)
# from drifting between editors.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{md,yml,yaml,json,toml}]
indent_size = 2

[*.{sh,bash,zsh}]
indent_size = 2

[Makefile]
indent_style = tab

# Tree-sitter / tantivy generated files — leave them alone.
[**/{generated,vendor}/**]
trim_trailing_whitespace = false
insert_final_newline = false
