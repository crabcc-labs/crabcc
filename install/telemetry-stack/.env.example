# crabcc hardened telemetry stack — copy to `.env` and fill in. No secrets are
# baked into the compose; it fails closed if these are unset.

# OpenObserve root account: the UI login. Use a long, unique password — keep it
# in a secrets manager, not here. (Prefer a dedicated ingest user/token for
# clients over reusing root — see README "Hardening".)
ZO_ROOT_USER_EMAIL=admin@example.com
ZO_ROOT_USER_PASSWORD=

# Cloudflare named-tunnel token: Zero Trust → Networks → Tunnels → (your
# tunnel) → install token. Route its public hostname to http://openobserve:5080.
CLOUDFLARE_TUNNEL_TOKEN=

# Local Parquet retention, days (OpenObserve compacts/expires past this).
ZO_RETENTION_DAYS=30
