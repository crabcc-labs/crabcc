# crabcc Ollama auth stack — env file — issue #105
#
# Copy to .env and fill in. NEVER commit the real .env.
#
#   cp .env.example .env
#   sed -i '' "s/changeme-ollama/$(openssl rand -hex 32)/" .env       # macOS
#   sed -i    "s/changeme-ollama/$(openssl rand -hex 32)/" .env       # Linux

# Bearer token Caddy enforces on /api and /v1 paths to Ollama.
# LiteLLM forwards this to upstream Ollama on every request.
OLLAMA_API_KEY=changeme-ollama-key-please-rotate

# Master key LiteLLM accepts on /v1/chat/completions, /v1/embeddings, etc.
# Send as: `Authorization: Bearer $LITELLM_MASTER_KEY`.
LITELLM_MASTER_KEY=sk-changeme-litellm-master-key-please-rotate

# Optional: override the host port Caddy binds to. Default 11435 (note: NOT
# 11434 to avoid colliding with a host-side Ollama install).
# CADDY_PORT=11435

# Optional: override the host port LiteLLM binds to. Default 4000.
# LITELLM_PORT=4000

# ── Optional Anthropic routing (used by crabcc-agents) ───────────────
#
# When ANTHROPIC_API_KEY is set, the LiteLLM proxy serves
# claude-sonnet-4-6 / claude-haiku-4-5 / claude-opus-4-7 with cost
# tracking, caching, fallbacks, and a single egress surface.
# ANTHROPIC_API_KEY=sk-ant-...

# Switch the response cache from in-memory `local` to Redis (survives
# restart, shared across replicas). Requires Redis reachable.
# LITELLM_CACHE_REDIS_URL=redis://redis:6379

# Optional Langfuse tracing — LiteLLM streams cost + latency via the
# `success_callback` hook. No-op when unset.
# LANGFUSE_HOST=https://cloud.langfuse.com
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...

# Compression-interception is enabled in litellm.config.yaml by default
# (it kicks in only when prompt tokens exceed `compression_trigger:
# 10000`, so short prompts are unaffected). To disable for a specific
# deployment without editing the yaml, leave the proxy's
# LITELLM_DISABLE_COMPRESSION_INTERCEPTION env unset to keep enabled,
# or set to `1` to override the YAML.
# LITELLM_DISABLE_COMPRESSION_INTERCEPTION=1
