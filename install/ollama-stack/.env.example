# crabcc Ollama auth stack — env file — issue #105
#
# Copy to .env and fill in. NEVER commit the real .env.
#
#   cp .env.example .env
#   sed -i '' "s/changeme-ollama/$(openssl rand -hex 32)/" .env       # macOS
#   sed -i    "s/changeme-ollama/$(openssl rand -hex 32)/" .env       # Linux

# Bearer token Caddy enforces on /api and /v1 paths to Ollama.
# LiteLLM forwards this to upstream Ollama on every request.
OLLAMA_API_KEY=changeme-ollama-key-please-rotate

# Master key LiteLLM accepts on /v1/chat/completions, /v1/embeddings, etc.
# Send as: `Authorization: Bearer $LITELLM_MASTER_KEY`.
LITELLM_MASTER_KEY=sk-changeme-litellm-master-key-please-rotate

# Optional: override the host port Caddy binds to. Default 11435 (note: NOT
# 11434 to avoid colliding with a host-side Ollama install).
# CADDY_PORT=11435

# Optional: override the host port LiteLLM binds to. Default 4000.
# LITELLM_PORT=4000

# ── Optional Anthropic routing (used by crabcc-agents) ───────────────
#
# When ANTHROPIC_API_KEY is set, the LiteLLM proxy serves
# claude-sonnet-4-6 / claude-haiku-4-5 / claude-opus-4-7 with cost
# tracking, caching, fallbacks, and a single egress surface.
# ANTHROPIC_API_KEY=sk-ant-...

# Switch the response cache from in-memory `local` to Redis (survives
# restart, shared across replicas). Requires Redis reachable.
# LITELLM_CACHE_REDIS_URL=redis://redis:6379

# Optional Langfuse tracing — LiteLLM streams cost + latency via the
# `success_callback` hook. No-op when unset.
# LANGFUSE_HOST=https://cloud.langfuse.com
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...

# Compression-interception is enabled in litellm.config.yaml by default
# (it kicks in only when prompt tokens exceed `compression_trigger:
# 10000`, so short prompts are unaffected). To disable for a specific
# deployment without editing the yaml, leave the proxy's
# LITELLM_DISABLE_COMPRESSION_INTERCEPTION env unset to keep enabled,
# or set to `1` to override the YAML.
# LITELLM_DISABLE_COMPRESSION_INTERCEPTION=1

# ── crabcc-hitl-agent (Phase 0+) ─────────────────────────────────────
#
# Bearer token shared between the Telegram bot and the HITL service.
# Generate with `openssl rand -hex 32`. Both ends must agree:
#   - here:                            CRABCC_HITL_API_TOKEN
#   - in apps/crabcc-telegram/.env:    CRABCC_HITL_API_TOKEN
CRABCC_HITL_API_TOKEN=changeme-hitl-bearer-please-rotate

# Optional — pick a different model from `litellm.config.yaml`.
# Defaults to claude-haiku-4-5 (cheapest tool-capable Claude).
# CRABCC_HITL_MODEL=claude-sonnet-4-6

# Optional — bump to "debug" when chasing a bug; default "info".
# CRABCC_HITL_LOG_LEVEL=debug

# Optional — pin host ports. Both default to loopback-only mappings.
# CRABCC_HITL_PORT=9100
# CRABCC_HITL_MCP_PORT=9101

# Optional — disable the MCP sibling listener. Default enabled.
# CRABCC_HITL_MCP_ENABLED=false

# Optional — route OTel spans into the workspace's `rotel` collector.
# Empty disables tracing cleanly (the SDK never initializes).
# OTEL_EXPORTER_OTLP_ENDPOINT=http://rotel:4317
# OTEL_DEPLOYMENT_ENVIRONMENT=dev

# ── crabcc-hitl-agent — Phase 2 approval flow ──────────────────────
#
# Bot token used to send approval prompts and validate Mini App
# initData. Same value the Rust crabcc-telegram bot reads as
# TELEGRAM_BOT_TOKEN. Empty disables outbound prompts; tools listed
# in CRABCC_HITL_APPROVAL_REQUIRED_TOOLS then fail closed (deny).
# TELEGRAM_BOT_TOKEN=

# Fallback Telegram chat for approvals when /chat didn't carry one
# (MCP callers, scheduled jobs). Typically the bot owner's user id.
# CRABCC_HITL_TELEGRAM_OWNER_CHAT_ID=

# Wall-clock cap on a pending approval. Defaults to 120s.
# CRABCC_HITL_APPROVAL_TIMEOUT_S=120

# Comma-separated tool names that REQUIRE explicit approval. Defaults
# to `memory_remember,fetch_url`. Read-only tools auto-run.
# CRABCC_HITL_APPROVAL_REQUIRED_TOOLS=memory_remember,fetch_url

# ── cloudflared tunnel — public Mini App URL ───────────────────────
#
# Token-based Cloudflare tunnel exposing the Mini App at a public
# HTTPS URL. Optional service: starts only when launched with
# `--profile tunnel` or `COMPOSE_PROFILES=tunnel`.
# CLOUDFLARED_TUNNEL_TOKEN=
