# Multi-stage build for the crabcc binary itself — issue #105 / #107.
#
# Forward-looking: used by future hosted runs, the menubar app's bundled-
# binary path, and the dev compose overlay (install/dev/docker-compose.yml).
#
# Build:
#   DOCKER_BUILDKIT=1 docker build \
#     -t crabcc:local \
#     -f install/Dockerfile.crabcc .
#
# Smoke:
#   docker run --rm crabcc:local crabcc info
#
# Multi-arch:
#   docker buildx build --platform linux/amd64,linux/arm64 \
#     -t crabcc:multi -f install/Dockerfile.crabcc .

# ----------------------------------------------------------------------
# Stage 1: builder — full Rust toolchain + native deps for tree-sitter,
# sqlite, openssl. Cached via BuildKit `--mount=type=cache` so iterative
# rebuilds skip the full registry + target tree.
# ----------------------------------------------------------------------
ARG RUST_VERSION=1.83
FROM --platform=$BUILDPLATFORM rust:${RUST_VERSION}-slim-bookworm AS builder

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
      pkg-config \
      libssl-dev \
      libsqlite3-dev \
      cmake \
      git \
      ca-certificates && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /src

# Copy manifests first so dep resolution caches independently of source edits.
COPY Cargo.toml Cargo.lock ./
COPY crates ./crates
# AGENTS.md is `include_str!`'d into the binary at compile time.
COPY AGENTS.md README.md ./
# install/ is bundled — install-claude reads from it at runtime.
COPY install ./install

# BuildKit cache mounts for cargo registry, git deps, and target tree.
# Output the binary to /tmp before the cache mount detaches.
RUN --mount=type=cache,target=/usr/local/cargo/registry \
    --mount=type=cache,target=/usr/local/cargo/git \
    --mount=type=cache,target=/src/target \
    cargo build --release --bin crabcc && \
    cp /src/target/release/crabcc /tmp/crabcc && \
    strip /tmp/crabcc

# ----------------------------------------------------------------------
# Stage 2: runtime — minimal Debian slim with only the dynamic libraries
# crabcc actually needs. Non-root user. Healthcheck via `crabcc info`.
# ----------------------------------------------------------------------
FROM debian:bookworm-slim AS runtime

# Build-time metadata — pass via --build-arg from `task images-build`
# (which fills git revision + ISO-8601 timestamp).
ARG GIT_SHA=unknown
ARG BUILD_DATE=unknown
ARG VERSION=dev

# OCI Image-Spec annotations + crabcc-specific labels for traceability.
LABEL org.opencontainers.image.title="crabcc"
LABEL org.opencontainers.image.description="Symbol index for AI coding agents"
LABEL org.opencontainers.image.url="https://github.com/peterlodri-sec/crabcc"
LABEL org.opencontainers.image.source="https://github.com/peterlodri-sec/crabcc"
LABEL org.opencontainers.image.documentation="https://github.com/peterlodri-sec/crabcc/blob/main/README.md"
LABEL org.opencontainers.image.vendor="peterlodri-sec"
LABEL org.opencontainers.image.licenses="MIT OR Apache-2.0"
LABEL org.opencontainers.image.version="${VERSION}"
LABEL org.opencontainers.image.revision="${GIT_SHA}"
LABEL org.opencontainers.image.created="${BUILD_DATE}"
LABEL com.crabcc.role="binary"
LABEL com.crabcc.issue="#105"
LABEL com.crabcc.build.local="true"

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
      ca-certificates \
      libssl3 \
      libsqlite3-0 \
      git && \
    rm -rf /var/lib/apt/lists/* && \
    useradd --create-home --uid 1000 --shell /usr/sbin/nologin crabcc

COPY --from=builder /tmp/crabcc /usr/local/bin/crabcc

# Default working dir is the user's home; mount your repo at /workspace
# and pass --root /workspace to operate on it.
USER crabcc
WORKDIR /home/crabcc

# Lightweight liveness — `crabcc info` does compile-time-embedded git lookup,
# so it touches no I/O and exits in milliseconds.
HEALTHCHECK --interval=30s --timeout=5s --start-period=5s --retries=3 \
    CMD ["crabcc", "info"]

ENTRYPOINT ["crabcc"]
CMD ["--help"]
