# Multi-stage build for the crabcc binary itself — issue #105 / #107.
#
# Forward-looking: used by future hosted runs, the menubar app's bundled-
# binary path, and the dev compose overlay (install/dev/docker-compose.yml).
#
# Build:
#   DOCKER_BUILDKIT=1 docker build \
#     -t crabcc:local \
#     -f install/Dockerfile.crabcc .
#
# Smoke:
#   docker run --rm crabcc:local crabcc info
#
# Multi-arch:
#   docker buildx build --platform linux/amd64,linux/arm64 \
#     -t crabcc:multi -f install/Dockerfile.crabcc .

# ----------------------------------------------------------------------
# Stage 1: builder — full Rust toolchain + native deps for tree-sitter,
# sqlite, openssl. Cached via BuildKit `--mount=type=cache` so iterative
# rebuilds skip the full registry + target tree.
# ----------------------------------------------------------------------
# 1. Use the nightly channel
# Stage 1: Build the frontend
FROM node:18 AS frontend-builder
WORKDIR /web
COPY crates/crabcc-viz/web/package*.json ./
RUN npm install
COPY crates/crabcc-viz/web/ ./
RUN npm run build  # This creates the /web/dist folder

ARG RUST_VERSION=nightly
FROM --platform=$BUILDPLATFORM rustlang/rust:nightly-slim AS builder

# 2. Tell Cargo to allow the unstable 'profile-rustflags' feature globally
ENV CARGO_UNSTABLE_PROFILE_RUSTFLAGS=true

RUN apt-get update && \
    apt-get install -y build-essential --no-install-recommends \
      pkg-config \
      libssl-dev \
      libsqlite3-dev \
      cmake \
      git \
      ca-certificates && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /src

# Copy manifests first so dep resolution caches independently of source edits.
COPY crates ./crates
COPY schema ./schema
COPY Cargo.toml Cargo.lock ./
COPY Cargo.toml Cargo.lock ./
# AGENTS.md is `include_str!`'d into the binary at compile time.
COPY AGENTS.md ./
# install/ is bundled — install-claude reads from it at runtime.
COPY install ./install

COPY --from=frontend-builder /web/dist ./crates/crabcc-viz/web/dist
# BuildKit cache mounts for cargo registry, git deps, and target tree.
# Output the binary to /tmp before the cache mount detaches.
RUN --mount=type=cache,target=/usr/local/cargo/registry \
    --mount=type=cache,target=/usr/local/cargo/git \
    --mount=type=cache,target=/src/target \
    cargo build -Z unstable-options --release --bin crabcc && \
    cp /src/target/release/crabcc /tmp/crabcc && \
    strip /tmp/crabcc

# ----------------------------------------------------------------------
# Stage 2: runtime — minimal Debian slim with only the dynamic libraries
# crabcc actually needs. Non-root user. Healthcheck via `crabcc info`.
# ----------------------------------------------------------------------
# Use the base image for baked TZ (Europe/Budapest) + locale (en_US.UTF-8)
# and the pre-created crabcc user. Build it once with:
#   docker build -t crabcc-base:local -f install/Dockerfile.base .
FROM crabcc-base:local AS runtime

# Build-time metadata — pass via --build-arg from `task images-build`
ARG GIT_SHA=unknown
ARG BUILD_DATE=unknown
ARG VERSION=dev

LABEL org.opencontainers.image.title="crabcc"
LABEL org.opencontainers.image.description="Symbol index for AI coding agents"
LABEL org.opencontainers.image.url="https://github.com/peterlodri-sec/crabcc"
LABEL org.opencontainers.image.source="https://github.com/peterlodri-sec/crabcc"
LABEL org.opencontainers.image.documentation="https://github.com/peterlodri-sec/crabcc/blob/main/README.md"
LABEL org.opencontainers.image.vendor="peterlodri-sec"
LABEL org.opencontainers.image.licenses="MIT OR Apache-2.0"
LABEL org.opencontainers.image.version="${VERSION}"
LABEL org.opencontainers.image.revision="${GIT_SHA}"
LABEL org.opencontainers.image.created="${BUILD_DATE}"
LABEL com.crabcc.role="binary"
LABEL com.crabcc.issue="#105"
LABEL com.crabcc.build.local="true"
# OTel resource attributes — used by rotel and any OTLP collector to
# tag all spans/metrics/logs from this container (issue #86).
LABEL org.opentelemetry.service.name="crabcc"
LABEL org.opentelemetry.service.version="${VERSION}"
LABEL org.opentelemetry.service.namespace="crabcc"

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
      libssl3 \
      libsqlite3-0 \
      git && \
    rm -rf /var/lib/apt/lists/*

COPY --from=builder /tmp/crabcc /usr/local/bin/crabcc

# Default working dir is the user's home; mount your repo at /workspace
# and pass --root /workspace to operate on it.
USER crabcc
WORKDIR /home/crabcc

# Lightweight liveness — `crabcc info` does compile-time-embedded git lookup,
# so it touches no I/O and exits in milliseconds.
HEALTHCHECK --interval=30s --timeout=5s --start-period=5s --retries=3 \
    CMD ["crabcc", "info"]

ENTRYPOINT ["crabcc"]
CMD ["--help"]
