# crabcc agent kernel config fragment — Apple Containers / Virtualization.framework
#
# Minimal ARM64 Linux kernel for crabcc agent containers.
# Merge into a base defconfig:
#   make ARCH=arm64 defconfig
#   scripts/kconfig/merge_config.sh .config install/kernel/config.fragment
#   make ARCH=arm64 Image.gz
#
# Reference: https://github.com/apple/containerization/tree/main/kernel
# Target: Linux 6.6 LTS on Apple Silicon (VZ framework, no Metal passthrough)

# ── Core / boot ───────────────────────────────────────────────────────────────
CONFIG_64BIT=y
CONFIG_ARM64=y
CONFIG_THUMB2_KERNEL=n
CONFIG_SMP=y
CONFIG_NR_CPUS=16

# ── VirtIO (required for Apple Virtualization.framework) ─────────────────────
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_BALLOON=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_CONSOLE=y
CONFIG_VIRTIO_INPUT=n
CONFIG_VIRTIO_GPU=n
CONFIG_HW_RANDOM_VIRTIO=y
CONFIG_VSOCKETS=y
CONFIG_VIRTIO_VSOCKETS=y

# ── Networking (TCP/TLS for Ollama API calls) ─────────────────────────────────
CONFIG_NET=y
CONFIG_INET=y
CONFIG_IPV6=y
CONFIG_TCP_CONG_CUBIC=y
CONFIG_NETFILTER=y
CONFIG_NF_TABLES=y
# No iptables legacy
CONFIG_IP_NF_IPTABLES=n

# ── Filesystems ───────────────────────────────────────────────────────────────
CONFIG_EXT4_FS=y
CONFIG_OVERLAY_FS=y
CONFIG_TMPFS=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# ── Memory / performance ──────────────────────────────────────────────────────
CONFIG_TRANSPARENT_HUGEPAGE=y
CONFIG_TRANSPARENT_HUGEPAGE_ALWAYS=n
CONFIG_TRANSPARENT_HUGEPAGE_MADVISE=y
CONFIG_ZSWAP=y
CONFIG_ZSMALLOC=y
# Large model weights benefit from huge pages; agents do many mmap calls.
CONFIG_HUGETLBFS=y
CONFIG_HUGETLB_PAGE=y

# ── CGroups (container isolation) ────────────────────────────────────────────
CONFIG_CGROUPS=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_MEMCG=y
CONFIG_CGROUP_BLKIO=y
CONFIG_NAMESPACES=y
CONFIG_USER_NS=y
CONFIG_NET_NS=y
CONFIG_PID_NS=y
CONFIG_IPC_NS=y
CONFIG_UTS_NS=y

# ── Security ─────────────────────────────────────────────────────────────────
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y
CONFIG_SECURITY=y
CONFIG_SECURITY_SELINUX=n
CONFIG_SECURITY_APPARMOR=n

# ── Strip unnecessary subsystems ─────────────────────────────────────────────
CONFIG_SOUND=n
CONFIG_DRM=n
CONFIG_FB=n
CONFIG_USB=n
CONFIG_HID=n
CONFIG_INPUT=n
CONFIG_WIRELESS=n
CONFIG_NFC=n
CONFIG_BLUETOOTH=n
CONFIG_PCCARD=n
CONFIG_MEDIA_SUPPORT=n
CONFIG_AGP=n
CONFIG_ACPI=n
CONFIG_X86_PLATFORM_DEVICES=n
CONFIG_FTRACE=n
CONFIG_KPROBES=n
CONFIG_PERF_EVENTS=n
