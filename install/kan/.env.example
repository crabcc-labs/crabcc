# kan self-hosted — env config
# Copy to .env: cp install/kan/.env.example install/kan/.env

# Required
POSTGRES_PASSWORD=changeme-strong-password-here
BETTER_AUTH_SECRET=changeme-32-chars-random-string

# Optional
KAN_PORT=3000
KAN_BASE_URL=http://localhost:3000
# For HTTPS (expose via reverse proxy or tunnel):
# KAN_BASE_URL=https://kan.yourdomain.com
