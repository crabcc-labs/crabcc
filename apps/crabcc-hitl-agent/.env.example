# Copy to `.env` for `docker compose up`. Never commit `.env`.

# Bearer token shared with the telegram bot. Generate with:
#   openssl rand -hex 32
CRABCC_HITL_API_TOKEN=

# LiteLLM master/virtual key — must match install/ollama-stack/.env's
# LITELLM_MASTER_KEY (or a virtual key issued by the proxy admin).
CRABCC_HITL_LITELLM_API_KEY=

# Optional overrides — defaults are baked into settings.py.
# CRABCC_HITL_LITELLM_BASE_URL=http://litellm:4000
# CRABCC_HITL_MODEL=claude-haiku-4-5
# CRABCC_HITL_MAX_TASK_CHARS=4000
