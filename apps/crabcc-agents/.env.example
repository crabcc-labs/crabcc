# crabcc-agents service env. Copy to .env (which is gitignored).

# Service URLs go through the same resolver as crabcc_core::service_discovery.
# Resolution: explicit env var > CRABCC_COMPOSE=1 default > localhost default.
# Setting CRABCC_COMPOSE=1 flips defaults to compose-network names (e.g.
# `redis://redis:6379` instead of `redis://127.0.0.1:6379`) so the same
# binary runs unchanged inside docker-compose.

# CRABCC_COMPOSE=1
REDIS_URL=redis://127.0.0.1:6379

# LiteLLM proxy. Worker preflights this at boot via TCP probe. Set to
# `-` or `none` to disable preflight (e.g. running without LiteLLM).
LITELLM_BASE_URL=http://127.0.0.1:4000

# Hard-fail boot when LiteLLM is unreachable. Off by default — preflight
# warns but the worker keeps running. Flip to 1 in production.
# LITELLM_REQUIRED=1
LITELLM_PROBE_TIMEOUT_MS=1500
AGENTS_QUEUE=crabcc:agents
AGENTS_CONCURRENCY=4
# 50 ms = ~25 ms p50 wakeup latency, ~4 ms/s of CPU per worker. Drop
# to 10 ms for tighter cold-start at the cost of more idle polling.
AGENTS_POLL_MS=50
AGENTS_HEALTH_ADDR=0.0.0.0:9090

# Pre-warm: at boot, inspect the agent image and pull only if missing.
# Surfaces a wrong AGENT_IMAGE at startup instead of mid-job and
# primes the daemon's layer cache. Set to 0/false/no to disable.
AGENTS_PREWARM=1

# Tokio worker threads. Default = min(host_cores, 4). The worker is
# IO-bound (Redis + Docker), not CPU-bound; more threads add context-
# switch overhead without throughput.
# AGENTS_TOKIO_THREADS=4

AGENT_IMAGE=ghcr.io/peterlodri-sec/crabcc-agent-runner:latest

# Per-container resource caps (bytes / micro-CPUs).
AGENT_MEMORY_BYTES=2147483648
AGENT_CPU_QUOTA=200000
AGENT_CPU_PERIOD=100000
AGENT_SHM_BYTES=268435456
AGENT_PIDS_LIMIT=256
AGENT_TMPFS_WORKSPACE_BYTES=1073741824
AGENT_TMPFS_TMP_BYTES=536870912
AGENT_TIMEOUT_SECS=1800

# Defaults (per-job payload may override).
AGENT_DEFAULT_MODEL=claude-sonnet-4-6
AGENT_DEFAULT_EFFORT=high

# mini-swe-agent caps — only consumed when a job's `kind` is
# "mini-swe". The yaml in /etc/crabcc-agent/mini.yaml already sets
# defaults (50 steps, $5 cost); these env overrides flow through to
# the entrypoint as --step-limit / --cost-limit.
# MINI_STEP_LIMIT=50
# MINI_COST_LIMIT=5.0

# Trackability headers — any env starting with CRABCC_HEADER_ is
# scooped into the BullMQ job at producer time and propagates through
# the worker, the per-job Redis stream, and the agent container.
# Convention: x-prefixed lower-case keys (HTTP idiom).
#
# CRABCC_HEADER_X_SOURCE=cli         # or telegram, live-web, pr-bot
# CRABCC_HEADER_X_REQUEST_ID=req-...
# CRABCC_HEADER_X_TRACE_ID=...
# CRABCC_HEADER_X_JOB_RUN_ID=...
#
# Headers ride through Redis logs + container env + upstream LLM
# logs — keep them PII-free. Use opaque correlation ids only.

# Redis Streams.
STREAM_MAXLEN=10000
STREAM_KEY_PREFIX=crabcc:agent:logs

# Claude Code SSO auth pass-through.
#
# Preferred: bind-mount the host's credentials file into each agent
# container, read-only. Path is resolved on the *host* (Docker bind
# semantics), so set the absolute host path here.
#   - default (unset): $HOME/.claude/.credentials.json
#   - set "-" or "none" to disable the mount
HOST_CLAUDE_CREDENTIALS=

# Fallback for hosts that don't expose a credentials file (e.g. macOS
# Keychain). Extract via `claude setup-token` and paste here. Only used
# when HOST_CLAUDE_CREDENTIALS is disabled or the file is missing.
# CLAUDE_CODE_OAUTH_TOKEN=

# Host-running axint MCP (HTTP). When set, agent containers connect to
# the host's `axint-mcp-http` over HTTP via host.docker.internal — they
# share the host's warm caches, project memory pack, and fix-packet
# history. Leave blank to keep the in-container stdio default.
#
#   on the host:  axint-mcp-http --port 7785
# HOST_AXINT_MCP_URL=http://host.docker.internal:7785/mcp

# Docker network for agent containers when HOST_AXINT_MCP_URL is set.
# Default `bridge` works on Docker Desktop. Override to a dedicated
# network (e.g. `crabcc-agents-egress` with iptables-restricted egress)
# to narrow the blast radius.
# AGENT_NETWORK=bridge
