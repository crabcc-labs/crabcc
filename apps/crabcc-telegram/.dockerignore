# Build context = apps/crabcc-telegram/ (this Dockerfile lives next to
# its build context, not at the repo root).

# Rust build artifacts
target/

# Secrets — NEVER ship these into the image; pass at run time via
# `--env-file` instead.
.env
.env.*
*.local.*
*.pem
*.key
telegram_setup.log

# Editor / IDE
.idea/
.vscode/
.DS_Store
*.swp

# VCS
.git/
.gitignore
