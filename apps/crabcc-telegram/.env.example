# crabcc-telegram — required runtime secrets
# Copy: cp apps/crabcc-telegram/.env.example apps/crabcc-telegram/.env
# NEVER commit .env

# Required
TELEGRAM_BOT_TOKEN=<from BotFather>
TELEGRAM_CHAT_ID=<your chat_id — run: task telegram-setup>

# Optional
CRABCC_SERVE_URL=http://localhost:8090
CRABCC_PUBLIC_URL=https://xxxx.trycloudflare.com  # for /live Mini App WebApp button
ALLOWED_TELEGRAM_IDS=                              # comma-sep IDs; empty = open

# Web status UI port (served by the bot container)
BOT_WEB_PORT=8092
