# Excluded from Docker / devcontainer build contexts.
# Mirrors .gitignore plus a few build-only paths that .gitignore tolerates.

# Rust artifacts (huge, regenerated by `cargo build`)
/target
**/*.rs.bk

# Per-repo crabcc index — never useful in a container
.crabcc/

# Bench raw transcripts are noisy + reproducible; the rendered REPORT
# stays readable as part of the source tree.
bench/results/raw.json
bench/results/*-raw.json
bench/results/*-crabcc.json
bench/results/summary.json

# IDE / OS noise
.DS_Store
.idea/
.vscode/
!.vscode/settings.json
*.swp
*.swo

# Git metadata isn't needed inside the container; saves megabytes.
.git/
.gitignore

# Local tooling caches we never want to ship.
.crabcc-bench-venv/
__pycache__/
*.pyc

# CI / GitHub workflows aren't needed inside the build context.
.github/

# Documentation that's served from the README / repo, not from the container.
CHANGELOG.md
examples/

# Editor backups.
*.bak

# Issue #105 — extra exclusions to keep the agent build context small.
# Mirrors .gitignore additions.
.summary/
.repomix/
/docs/
/bench/

# Built artifacts under crates/crabcc-viz/web/ — esbuild rebuilds dist/
# inside the dev compose's viz-web service, no value shipping the host
# build into the crabcc image.
crates/crabcc-viz/web/dist/
crates/crabcc-viz/web/node_modules/
crates/crabcc-viz/web/bun.lock
