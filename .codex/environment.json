{
  "setup": [
    "apt-get update -qq && apt-get install -y --no-install-recommends clang mold libsqlite3-dev libssl-dev pkg-config",
    "sh -c \"$(curl -fsSL https://taskfile.dev/install.sh)\" -- -d -b /usr/local/bin",
    "cargo install --locked sccache cargo-nextest",
    "rustup component add clippy rustfmt rust-src"
  ],
  "env": {
    "RUST_BACKTRACE": "1",
    "CARGO_TERM_COLOR": "always",
    "RUSTC_WRAPPER": "sccache",
    "CRABCC_AUTO_MEMORY": "1",
    "CARGO_TARGET_X86_64_UNKNOWN_LINUX_GNU_LINKER": "clang",
    "CARGO_TARGET_X86_64_UNKNOWN_LINUX_GNU_RUSTFLAGS": "-C link-arg=-fuse-ld=mold"
  }
}
