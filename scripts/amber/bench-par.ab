#!/usr/bin/env amber
// bench-par.ab — parallel benchmark workload (Amber side of amber-vs-bash comparison)
//
// Simulates 10 independent 0.1s tasks running concurrently.
// Expected wall time: ~0.1s regardless of task count.
// Compare: bash scripts/amber/bench-seq.sh (expected: ~1.0s)

main {
    let pids = [] as [Int]

    for _ in 0..10 {
        trust $sleep 0.1 &$
        pids += [pid()]
    }

    trust await(pids)
}
