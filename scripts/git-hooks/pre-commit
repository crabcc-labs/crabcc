#!/usr/bin/env bash
# ---------------------------------------------------------------------------
# crabcc :: .git/hooks/pre-commit (installed by scripts/install-hooks.sh)
#
# Sensible local pre-commit gate. Goals:
#   * Catch fmt + clippy regressions before they reach CI
#   * Run the aliases-smoke (cheap shell-only assertion)
#   * Stay under ~15s on a warm cache so it doesn't impede `git commit`
#   * No tests (those run in `task ci` / `task local-ci`)
#
# Bypass with `git commit --no-verify` if you really need to (rare).
# Skip entirely with `CRABCC_SKIP_HOOKS=1 git commit ...`.
# ---------------------------------------------------------------------------

set -uo pipefail

if [ "${CRABCC_SKIP_HOOKS:-0}" = "1" ]; then
    echo "[crabcc-hooks] CRABCC_SKIP_HOOKS=1 — skipping pre-commit"
    exit 0
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT" || exit 1

# Only run if Rust files or shell scripts changed. Doc-only commits skip.
changed="$(git diff --cached --name-only --diff-filter=ACMR || true)"
if [ -z "$changed" ]; then
    exit 0
fi

run_rust=0
run_shell=0
run_image=0
run_ts=0
run_workflows=0
run_openapi=0
while IFS= read -r f; do
    case "$f" in
        *.rs|Cargo.toml|Cargo.lock|crates/*/Cargo.toml) run_rust=1 ;;
        scripts/install-aliases.sh|scripts/aliases-smoke.sh) run_shell=1 ;;
        *.png|*.PNG|*.jpg|*.JPG|*.jpeg|*.JPEG) run_image=1 ;;
        crates/crabcc-viz/web/src/*.ts|\
        crates/crabcc-viz/web/src/*.tsx|\
        crates/crabcc-viz/web/src/**/*.ts|\
        crates/crabcc-viz/web/src/**/*.tsx|\
        crates/crabcc-viz/web/package.json) run_ts=1 ;;
        .github/workflows/*.yml|.github/workflows/*.yaml) run_workflows=1 ;;
        crates/crabcc-viz/openapi.yaml) run_openapi=1 ;;
    esac
done <<<"$changed"

if [ "$run_rust" = "0" ] && [ "$run_shell" = "0" ] && [ "$run_image" = "0" ] \
   && [ "$run_ts" = "0" ] && [ "$run_workflows" = "0" ] && [ "$run_openapi" = "0" ]; then
    exit 0
fi

echo "[crabcc-hooks] pre-commit fast gate"

# Autofix mode: rewrite the working tree, then re-stage what changed.
# This means a hook that "fails" because of formatting will produce a
# fixed-up index automatically — re-run `git commit` to land it.
if [ "$run_rust" = "1" ]; then
    echo "  → cargo fmt --all"
    if ! cargo fmt --all; then
        echo "[crabcc-hooks] cargo fmt failed — fix and re-commit" >&2
        exit 1
    fi
    echo "  → cargo clippy --workspace --lib --bins -- -D warnings"
    if ! cargo clippy --workspace --lib --bins -- -D warnings 2>&1 | tail -20; then
        echo "[crabcc-hooks] clippy failed — fix and re-commit" >&2
        exit 1
    fi
fi

if [ "$run_shell" = "1" ]; then
    echo "  → bash scripts/aliases-smoke.sh"
    if ! bash scripts/aliases-smoke.sh; then
        echo "[crabcc-hooks] aliases-smoke failed — fix and re-commit" >&2
        exit 1
    fi
fi

# Re-stage any files that fmt rewrote.
if [ "$run_rust" = "1" ]; then
    fmt_changed="$(git diff --name-only --diff-filter=M -- '*.rs' || true)"
    if [ -n "$fmt_changed" ]; then
        echo "[crabcc-hooks] re-staging fmt-rewritten files:"
        # shellcheck disable=SC2086
        git add $fmt_changed
        echo "$fmt_changed" | sed 's/^/    /'
    fi
fi

# Lossless image compression. Shrinks staged PNG/JPEG before commit so the
# repo doesn't accumulate fat assets. Uses oxipng + jpegoptim if installed;
# warns and continues if missing. Re-stages the now-smaller files.
if [ "$run_image" = "1" ]; then
    echo "  → compress-images (staged PNG/JPEG)"
    if [ -x "$REPO_ROOT/scripts/compress-images.sh" ]; then
        bash "$REPO_ROOT/scripts/compress-images.sh" --staged
        # Re-stage anything compress-images shrunk.
        img_changed="$(git diff --name-only --diff-filter=M | grep -iE '\.(png|jpe?g)$' || true)"
        if [ -n "$img_changed" ]; then
            echo "[crabcc-hooks] re-staging compressed images:"
            echo "$img_changed" | while IFS= read -r f; do git add "$f"; done
            echo "$img_changed" | sed 's/^/    /'
        fi
    else
        echo "  ⚠ scripts/compress-images.sh not executable — skipping" >&2
    fi
fi

# TypeScript typecheck — fast (~2 s warm). Only when web/src or package.json changed.
if [ "$run_ts" = "1" ]; then
    if command -v bun >/dev/null 2>&1; then
        echo "  → bun run typecheck (crabcc-viz/web)"
        if ! (cd "$REPO_ROOT/crates/crabcc-viz/web" && bun run typecheck 2>&1 | tail -30); then
            echo "[crabcc-hooks] TypeScript typecheck failed — fix and re-commit" >&2
            exit 1
        fi
    else
        echo "  ⚠ bun not found — skipping TypeScript typecheck" >&2
    fi
fi

# actionlint — validates staged workflow YAML files against the GHA schema.
# Catches most "why is CI broken?" issues before the first push.
if [ "$run_workflows" = "1" ]; then
    if command -v actionlint >/dev/null 2>&1; then
        echo "  → actionlint (staged workflow files)"
        WORKFLOW_FILES=$(echo "$changed" | grep -E '^\.github/workflows/.*\.ya?ml$' || true)
        if [ -n "$WORKFLOW_FILES" ]; then
            # shellcheck disable=SC2086
            if ! echo "$WORKFLOW_FILES" | xargs actionlint 2>&1; then
                echo "[crabcc-hooks] actionlint failed — fix and re-commit" >&2
                exit 1
            fi
        fi
    else
        echo "  ⚠ actionlint not found — skipping workflow lint (brew install actionlint)" >&2
    fi
fi

# YAML validity check for openapi.yaml — catches syntax errors before they
# break the TypeScript codegen step in the frontend build.
if [ "$run_openapi" = "1" ]; then
    if command -v yq >/dev/null 2>&1; then
        echo "  → yq validate openapi.yaml"
        if ! yq eval '.' "$REPO_ROOT/crates/crabcc-viz/openapi.yaml" >/dev/null 2>&1; then
            echo "[crabcc-hooks] openapi.yaml: invalid YAML — fix and re-commit" >&2
            exit 1
        fi
    fi
fi

# Refresh the paste-ready PR summary so `gh pr create --body-file
# .summary/gen-summary.md` always reflects the latest commit. Pure git
# ops; ~200 ms; never fails the hook (`|| true`).
if [ -x "$REPO_ROOT/scripts/gen-summary.sh" ]; then
    bash "$REPO_ROOT/scripts/gen-summary.sh" --quiet || true
fi

echo "[crabcc-hooks] ✓ pre-commit passed"
exit 0
