/target
**/*.rs.bk
.crabcc/
# DMG installer build outputs (scripts/build-dmg.sh)
/dist/
/build/
.DS_Store
# Per-developer scratch — task outputs land here (local-ci, smoke,
# coverage, profiling, ollama smoke replies). Kept on disk between
# runs but never checked in.
.summary/

# Local-only — no longer published to the remote. Kept on disk for the
# author's reference; ship-relevant content lives in README.md, CLAUDE.md,
# AGENTS.md, CHANGELOG.md, and the in-source rustdoc.
/bench/
/docs/
/ARCHITECTURE.md

# Research artifacts produced by sub-agents — not source.
STORAGE_RESEARCH.md
DB_*.md
crates/crabcc-core/fuzz/target/

# Generated secrets for the Ollama auth stack. Real .env never committed;
# track install/ollama-stack/.env.example instead. See issue #105.
install/ollama-stack/.env
# User-facing api-key file (chmod 0400). Lives in $HOME normally;
# the rule is here as defense-in-depth in case a developer copies
# it into the repo by accident.
.crabcc.local.api-key
**/.crabcc.local.api-key
# Per-agent repomix bundles emitted by `crabcc agent` (issue #112).
/repomix-outs/
**/repomix-outs/
# Per-repo backups, if they ever land inside a checkout (the canonical
# location is $CRABCC_HOME/backups/, but defensive ignore is cheap).
/backups/
.repomix/

# Python bytecode caches (apps/crabcc-iterm2 and any other Python tooling).
__pycache__/
*.pyc
*.pyo
