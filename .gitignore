/target
**/*.rs.bk
.crabcc/

# Nix: flake build symlinks + nix-direnv cache.
/result
/result-*
.direnv/
# Build / packaging output dirs
/dist/
/build/
.DS_Store
# Node / bun package directories. bun.lock IS tracked (intentional lockfile);
# node_modules/ is never committed. The per-crate web frontend
# (crates/crabcc-viz/web/) has its own .gitignore for node_modules/;
# this root-level pattern covers apps/ (jobs-worker, etc.) that lack
# a per-directory .gitignore.
node_modules/
# IDE project metadata — JetBrains and VS Code.
.idea/
.vscode/
!.vscode/settings.json
# Vim swap files.
*.swp
*.swo
# Per-developer scratch — task outputs land here (local-ci, smoke,
# coverage, profiling, ollama smoke replies). Kept on disk between
# runs but never checked in.
.summary/
# git worktrees created by `task dev:local:start`. Each is a full checkout
# at a specific branch; gitignored so the parent repo doesn't track them.
.worktrees/

# Local-only — no longer published to the remote. Kept on disk for the
# author's reference; ship-relevant content lives in README.md, CLAUDE.md,
# AGENTS.md, CHANGELOG.md, and the in-source rustdoc.
/bench/
/ARCHITECTURE.md
# /docs/ is now a private submodule (peterlodri-sec/crabcc-docs).
# Only the gitlink + .gitmodules are tracked; submodule contents stay
# in the submodule's own history.

# Research artifacts produced by sub-agents — not source.
STORAGE_RESEARCH.md
DB_*.md
crates/crabcc-core/fuzz/target/
crates/crabcc-viz/target/

# Generated secrets for the Ollama auth stack. Real .env never committed;
# track install/ollama-stack/.env.example instead. See issue #105.
install/ollama-stack/.env
# User-facing api-key file (chmod 0400). Lives in $HOME normally;
# the rule is here as defense-in-depth in case a developer copies
# it into the repo by accident.
.crabcc.local.api-key
**/.crabcc.local.api-key
# Per-agent repomix bundles emitted by `crabcc agent` (issue #112).
/repomix-outs/
**/repomix-outs/
# Per-repo backups, if they ever land inside a checkout (the canonical
# location is $CRABCC_HOME/backups/, but defensive ignore is cheap).
/backups/
.repomix/

# Python bytecode caches (apps/crabcc-iterm2 and any other Python tooling).
__pycache__/
*.pyc
*.pyo

# Defense-in-depth: never commit `.env` files anywhere in the tree.
# Real env lives in $HOME or in a developer-private file. Templates
# go in `*.env.example` next to whatever consumes them.
.env
**/.env
.env.mastodon
# Claude Code per-project agent state in `.claude/` is local-only, EXCEPT the
# committed project settings.json (shared plugin/marketplace config). List
# contents (`*`) + negate the one tracked file; a bare `.claude/` would block
# the negation. Personal overrides go in the still-ignored settings.local.json.
.claude/*
**/.claude/*
!.claude/settings.json
# Per-run setup logs from interactive scripts.
*_setup.log
# esbuild metafile is internal to the build (used for analysis, regenerated
# every build). Bundle output lives next to it; only the `.html`/`.js`/`.css`
# chunks the Rust crate `include_str!`s should be tracked.
crates/crabcc-viz/web/dist/metafile.json

# act (nektos/act) local secrets file — copy from .secrets.example and fill in.
# Never commit real tokens.
.secrets

# ── SSH keys & credentials (never commit private keys) ───────────────
# Private keys (any algorithm, any name containing "id_")
id_*
!id_*.pub
!*.pub
# PEM-encoded private keys
*.pem
# OpenSSH certificates
*-cert.pub
# GPG private keys
*.gpg
!*.gpg.pub
secring.gpg
pubring.gpg
# OpenBao / Vault tokens
bao-agent-token
*vault-token*
*.vault
# Cloud / service-account credentials
service-account*.json
*credentials*.json
!*credentials*.example.json
# TLS certificates (private keys)
*.key
!*.key.pub
# PGP / age identity files
*.age
!*.age.pub

# ── CI / deployment artifacts ────────────────────────────────────────
# Terraform state (may contain secrets)
*.tfstate
*.tfstate.*
.terraform/
# Ansible vault files
*.vault.yml
*.vault.yaml
# kubectl config (contains cluster credentials)
.kube/
**/.kube/config

# ── Local agent / tooling state ──────────────────────────────────────
.claude-flow/
.deepseek/
.versions

# ── Python compact-server artifacts ──────────────────────────────────
compact-server/.venv/
compact-server/compact_server.egg-info/
